# Copy this file to netbird-server.env and adjust the values for your server.
# The script also accepts CLI flags and NETBIRD_* environment variables.

NETBIRD_DOMAIN=netbird.example.com
NETBIRD_INSTALL_DIR=/root/netbird-docker
NETBIRD_DASHBOARD_PORT=18084
NETBIRD_SERVER_PORT=18085
NETBIRD_STUN_PORT=13478
NETBIRD_BIND_ADDRESS=127.0.0.1
NETBIRD_PUBLIC_SCHEME=https
NETBIRD_PUBLIC_PORT=443

NETBIRD_DASHBOARD_IMAGE=netbirdio/dashboard:latest
NETBIRD_SERVER_IMAGE=netbirdio/netbird-server:latest

# Leave empty to derive it from NETBIRD_DOMAIN.
NETBIRD_1PANEL_ROOT_CONF=
